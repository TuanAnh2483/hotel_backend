@host = http://localhost:8080
@email = demo@example.com
@resetToken = REPLACE_RESET_TOKEN

### 1. Request password reset email
# MAIL_ENABLED=false: copy token from backend log.
# MAIL_ENABLED=true: copy token from the email link.
POST {{host}}/api/auth/forgot-password
Content-Type: application/json

{
  "email": "{{email}}"
}

### 2. Reset password with the token from the mock email log
POST {{host}}/api/auth/reset-password
Content-Type: application/json

{
  "token": "{{resetToken}}",
  "newPassword": "NewPassword123",
  "confirmPassword": "NewPassword123"
}
