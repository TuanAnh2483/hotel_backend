    {
      "name": "7. Partner Images",
      "item": [
        {
          "name": "Upload Hotel Images",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('hotel image upload returns gallery', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.imageUrls).to.be.an('array').and.not.empty;",
                  "});",
                  "if (json.data.imageUrls.length > 0) {",
                  "  pm.environment.set('hotelImageUrl', json.data.imageUrls[0]);",
                  "}",
                  "if (json.data.imageUrls.length > 1) {",
                  "  pm.environment.set('hotelImageUrlAlt', json.data.imageUrls[1]);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{partnerToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "files",
                  "type": "file",
                  "src": "C:/replace-me/hotel-cover.png"
                },
                {
                  "key": "files",
                  "type": "file",
                  "src": "C:/replace-me/hotel-lobby.jpg"
                }
